{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "anhskohbo/no-captcha": "^3.8",
        "botman/botman": "^2.8",
        "botman/driver-telegram": "^2.0",
        "guzzlehttp/guzzle": "^7.8.2",
        "laravel-notification-channels/telegram": "^7.0",
        "laravel/framework": "^12.0",
        "laravel/jetstream": "^5.0",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.27",
        "laravel/tinker": "^2.10",
        "livewire/livewire": "^3.6",
        "openspout/openspout": "^5.7",
        "stripe/stripe-php": "^20.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "laravel/sail": "^1.62",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.5"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "KingFlamez\\Rave\\": "app/Compat/Rave/",
            "Unicodeveloper\\Paystack\\": "app/Compat/Paystack/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
